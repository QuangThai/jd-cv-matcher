# OpenAI API Key (required)
OPENAI_API_KEY=your_openai_api_key_here

# NextAuth
AUTH_SECRET=your_auth_secret_at_least_32_chars
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=

# Database (SQLite — default is file:./prisma/dev.db)
DATABASE_URL="file:./prisma/dev.db"

# Set to "true" on Vercel/serverless to disable DB-dependent features
# (auth, saved analyses, history). Core analysis flow works without them.
NEXT_PUBLIC_DISABLE_DB_FEATURES=false
DISABLE_DB_FEATURES=false
